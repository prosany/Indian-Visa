{
  "manifest_version": 3,
  "name": "QNET Captcha",
  "version": "1.0",
  "description": "Get solved captchas for indian visa application process.",

  "permissions": ["scripting", "tabs", "storage"],

  "host_permissions": ["https://appointment.ivacbd.com/*", "<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },

  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["welcome.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "externally_connectable": {
    "matches": ["*://localhost/*"]
  }
}
